       {
        RichTextWidgetClass "{698428622C516AEE}" {
         Name "briefHeading"
         Slot LayoutSlot "{69842862B925EFD7}" {
          Padding 0 0 0 30
         }
         Text "Mission Briefing "
         "Font Size" 48
         "Min Font Size" 44
         FontProperties FontProperties "{6982524BA2F9DFF0}" {
          Font "{EABA4FE9D014CCEF}UI/Fonts/RobotoCondensed/RobotoCondensed_Bold.fnt"
         }
        }
        RichTextWidgetClass "{698428622C512AB9}" : "{E256BCCAE8821432}UI/layouts/WidgetLibrary/RichTextWidgets/RichText_Body.layout" {
         Name "brief0"
         Slot LayoutSlot "{69842862B925EFF6}" {
          HorizontalAlign 3
         }
         Clipping Inherit
         Text "You are entering an active operations environment where discipline, coordination, and adaptability determine survival. Our task force operates across contested territory with one objective: establish control, support allied forces, and eliminate hostile threats before they gain momentum."
         "Min Font Size" 16
         FontProperties FontProperties "{546AF489DFD25402}" {
         }
         "Line Spacing" 30
        }
        RichTextWidgetClass "{698428622C512ABE}" : "{E256BCCAE8821432}UI/layouts/WidgetLibrary/RichTextWidgets/RichText_Body.layout" {
         Name "brief1"
         Slot LayoutSlot "{69842862B925EF16}" {
          HorizontalAlign 3
          Padding 0 20 0 0
         }
         Clipping Inherit
         Text "Expect dynamic engagements, evolving objectives, heavy resistance, and limited second chances. Every patrol, convoy, airlift, resupply, and firefight contributes to the larger campaign."
         "Min Font Size" 16
         FontProperties FontProperties "{546AF489DFD25402}" {
         }
         "Line Spacing" 30
        }
        RichTextWidgetClass "{698428622C529654}" : "{E256BCCAE8821432}UI/layouts/WidgetLibrary/RichTextWidgets/RichText_Body.layout" {
         Name "brief2"
         Slot LayoutSlot "{69842862B925EF25}" {
          HorizontalAlign 3
          Padding 0 20 0 0
         }
         Clipping Inherit
         Text "Check your gear. Confirm your role. Stay with your element."
         "Min Font Size" 16
         FontProperties FontProperties "{546AF489DFD25402}" {
         }
         "Line Spacing" 30
        }
        RichTextWidgetClass "{698428622C529655}" : "{E256BCCAE8821432}UI/layouts/WidgetLibrary/RichTextWidgets/RichText_Body.layout" {
         Name "brief3"
         Slot LayoutSlot "{69842862B925EF36}" {
          HorizontalAlign 3
          Padding 0 20 0 0
         }
         Clipping Inherit
         Text "Command expects every operator to communicate clearly, follow orders, and act with purpose. Lone wolves become liabilities. Squads win wars."
         "Min Font Size" 16
         FontProperties FontProperties "{546AF489DFD25402}" {
         }
         "Line Spacing" 30
        }
        RichTextWidgetClass "{698428622C52BF89}" : "{E256BCCAE8821432}UI/layouts/WidgetLibrary/RichTextWidgets/RichText_Body.layout" {
         Name "brief4"
         Slot LayoutSlot "{6982524B9E2BC9EF}" {
          HorizontalAlign 3
          Padding 0 20 0 0
         }
         Clipping Inherit
         Text "Your mission begins now."
         "Min Font Size" 16
         FontProperties FontProperties "{546AF489DFD25402}" {
          Font "{EABA4FE9D014CCEF}UI/Fonts/RobotoCondensed/RobotoCondensed_Bold.fnt"
         }
         "Line Spacing" 30
        }
        RichTextWidgetClass "{698428622C525FF4}" : "{E256BCCAE8821432}UI/layouts/WidgetLibrary/RichTextWidgets/RichText_Body.layout" {
         Name "brief5"
         Slot LayoutSlot "{6982524B9E2BC9EF}" {
          HorizontalAlign 3
          Padding 0 20 0 0
         }
         Clipping Inherit
